# @Date: 2026-05-30
# @Author: xisy
# @Discription: EduWeave 后端环境变量示例

APP_NAME=EduWeave Backend
APP_ENV=development
APP_LOAD_DOTENV=1
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=boss1114
MYSQL_DATABASE=eduweave

REDIS_URI=redis://127.0.0.1:6379/0
TASK_EAGER_MODE=false
TASK_STALE_THRESHOLD_SECONDS=1800
TASK_REAPER_INTERVAL_SECONDS=300
TASK_RETRY_BACKOFF_BASE_SECONDS=30
COURSEWARE_REMOTE_POLL_INTERVAL_SECONDS=60

JWT_SECRET=please_change_me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_ALGORITHM=HS256

OBS_ENDPOINT=https://obs.cn-east-3.myhuaweicloud.com
OBS_AK=your_access_key
OBS_SK=your_secret_key
OBS_BUCKET=eduweave-bucket
OBS_BASE_PREFIX=projects
OBS_SIGNED_URL_EXPIRE_SECONDS=3600

MINERU_API_BASE_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL_SECONDS=3
MINERU_POLL_TIMEOUT_SECONDS=600
MINERU_DEFAULT_LANGUAGE=ch
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true

LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
# 结构化 LLM 调用格式：response 使用 /responses + json_schema；chat 使用 /chat/completions + json_object，适配 DeepSeek 等不支持 Responses 的网关。
# 重要：智能助手（agent）工具调用强制走 Responses 协议，此项必须保持 response。
# chat 流式下 reasoning 模型经第三方网关（如 packyapi gpt-5.5）会把工具调用的 name 与 arguments 错位到不同分片，导致回灌空参数 {}，工具反复失败。
LLM_API_FORMAT=response
# 可选。response 格式下传入 reasoning.effort；chat 格式下传入 reasoning_effort。留空则改用 temperature。
LLM_REASONING_EFFORT=
LLM_TIMEOUT_SECONDS=60
# 瞬时失败（429/5xx/超时/空文本/可恢复 SSE 流式错误）最大重试次数，0 表示不重试。
LLM_MAX_RETRIES=2
# 重试指数退避基数（秒），实际等待 base * 2**attempt。
LLM_RETRY_BASE_SECONDS=1
# LLM 流式错误安全详情最大字符串长度，避免任务详情落入超长上游响应。
LLM_STREAM_ERROR_DETAIL_MAX_CHARS=4096
# 结构化输出解析/校验失败时，回调 LLM 自修复 JSON 的最大次数，0 表示不修复。
LLM_PARSE_REPAIR_MAX_ATTEMPTS=2
# 知识抽取按语义块并行调用 LLM 的最大并发数，范围 1-10；1 等价于串行。
KNOWLEDGE_EXTRACT_MAX_CONCURRENCY=10
# 教案生成第 1 课暖缓存后，剩余课次并行调用 LLM 的最大并发数，范围 1-10；1 等价于串行。
LESSON_PLAN_MAX_CONCURRENCY=10
# 单课次教案生成在 LLM 客户端重试耗尽后的业务级重试次数，0 表示不重试。
LESSON_PLAN_SESSION_MAX_RETRIES=2
# 单课次教案生成业务级重试指数退避基数（秒）。
LESSON_PLAN_SESSION_RETRY_BASE_SECONDS=3

EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_SECONDS=60

RACCOON_API_HOST=https://xiaohuanxiong.com
RACCOON_API_TOKEN=
RACCOON_REQUEST_TIMEOUT_SECONDS=60
RACCOON_POLL_INTERVAL_SECONDS=5
RACCOON_SHORT_POLL_TIMEOUT_SECONDS=120

MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
# 可选。若当前 Milvus 已按独立库/集群隔离，可留空直接使用逻辑集合名。
MILVUS_COLLECTION_PREFIX=
MILVUS_EMBEDDING_DIM=1024
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE
